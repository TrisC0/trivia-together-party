{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": "web",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/host", "destination": "/host/index.html" },
      { "source": "/join", "destination": "/join/index.html" }
    ]
  },
  "emulators": {
    "auth": { "port": 9099 },
    "database": { "port": 9000 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": true }
  }
}
